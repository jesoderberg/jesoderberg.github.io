---
import Layout from '../layouts/Layout.astro';

const courses = [
  {
    title: 'Basic Scheduling',
    type: 'Professional Development Course',
    venue: 'USACE Learning Center (IACET Authorized Provider)',
    format: 'National, in-person and virtual classroom · 38 Districts, 8 Divisions',
    description: 'Foundational project scheduling theory and application within USACE program and project management AIS. Covers schedule development, baseline establishment, and performance tracking in the context of federal civil works and military construction programs.',
  },
  {
    title: 'Advanced Scheduling',
    type: 'Professional Development Course',
    venue: 'USACE Learning Center (IACET Authorized Provider)',
    format: 'National, in-person and virtual classroom · 38 Districts, 8 Divisions',
    description: 'Complex schedule analysis, earned value, and performance measurement using USACE enterprise systems. Designed for practitioners with foundational scheduling experience who manage high-complexity programs.',
  },
  {
    title: 'Civil Works Program',
    type: 'Professional Development Course',
    venue: 'USACE Learning Center (IACET Authorized Provider)',
    format: 'National, in-person and virtual classroom · 38 Districts, 8 Divisions',
    description: 'Civil Works program structure, appropriations, and program management AIS workflows. Addresses the federal budget process from project formulation and benefit-cost analysis through the President\'s Budget, Congressional justification, and appropriations cycle.',
  },
  {
    title: 'Military Officer Pre-Command',
    type: 'Professional Development Course',
    venue: 'USACE Learning Center (IACET Authorized Provider)',
    format: 'National, in-person and virtual classroom',
    description: 'Program and project management AIS orientation for officers preparing to assume command of USACE Districts and Divisions. Ensures incoming commanders have the system fluency to lead program execution from day one.',
  },
];
---

<Layout title="Teaching">

  <section class="relative bg-gray-950 border-b border-gray-800 overflow-hidden">
    <img
      src="/images/blueprint-hero-bg.png"
      alt=""
      class="absolute inset-0 w-full h-full object-cover object-right opacity-40"
    />
    <div class="relative max-w-3xl mx-auto px-6 py-24 text-center">
      <p class="text-blue-400 text-xs font-semibold tracking-[0.2em] uppercase mb-8">
        Education &amp; Instruction
      </p>
      <h1 class="text-4xl md:text-5xl font-bold leading-[1.15] tracking-tight mb-8 text-white">
        Teaching
      </h1>
      <p class="text-gray-400 text-base md:text-lg leading-relaxed max-w-xl mx-auto">
        National instructor at a Federal Learning Center operating as an IACET Authorized Provider
        authorized to issue Continuing Education Units (CEUs) under the ANSI/IACET Standard.
      </p>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-6 py-16">

    <div class="space-y-6">
      {courses.map((course) => (
        <div class="border border-gray-700 bg-gray-800 rounded-xl p-8">
          <span class="text-xs font-medium text-blue-400 bg-blue-900/30 px-2 py-0.5 rounded mb-3 inline-block">
            {course.type}
          </span>
          <h2 class="text-lg font-bold text-white mb-1">{course.title}</h2>
          <p class="text-sm text-gray-500 mb-1">{course.venue}</p>
          <p class="text-xs text-gray-600 mb-4">{course.format}</p>
          <p class="text-sm text-gray-400 leading-relaxed">{course.description}</p>
        </div>
      ))}
    </div>
  </div>
</Layout>
