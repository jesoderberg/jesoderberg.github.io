---
const navLinks = [
  { href: '/',             label: 'About' },
  { href: '/publications', label: 'Publications' },
  { href: '/teaching',     label: 'Teaching' },
  { href: '/portfolio',    label: 'Portfolio' },
  { href: '/cv',           label: 'CV' },
  { href: '/hobbies',      label: 'Hobbies' },
  { href: '/following',    label: 'Following' },
  { href: '/pai',          label: 'PAI' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="sticky top-0 z-50 bg-gray-900 border-b border-gray-800">
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between h-16">

    <!-- Brand -->
    <a href="/" class="font-bold text-white text-sm tracking-tight hover:text-blue-400 transition-colors whitespace-nowrap">
      J.E. Soderberg
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/' ? path === '/' : path.startsWith(href);
        return (
          <a
            href={href}
            class={[
              'text-sm font-medium px-3 py-2 rounded-md transition-colors',
              isActive
                ? 'text-blue-400 bg-gray-800'
                : 'text-gray-400 hover:text-white hover:bg-gray-800',
            ].join(' ')}
          >
            {label}
          </a>
        );
      })}

      <!-- GitHub -->
      <a
        href="https://github.com/jesoderberg"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="ml-3 text-gray-500 hover:text-white transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>

    <!-- Mobile toggle -->
    <button
      id="mobile-toggle"
      aria-label="Toggle menu"
      class="md:hidden text-gray-400 hover:text-white transition-colors"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-800 bg-gray-900">
    <div class="max-w-6xl mx-auto px-6 py-3 flex flex-col gap-1">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="py-2 text-sm font-medium text-gray-400 hover:text-white transition-colors">
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  document.getElementById('mobile-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
